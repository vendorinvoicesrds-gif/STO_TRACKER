<mvc:View controllerName="stolifecycle.controller.dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <Page id="page" title="STO Operations Cockpit" class="customPageHeader">

        <content >
           
            <HBox id="_IDGenHBox"
                wrap="Wrap"
                justifyContent="SpaceAround"
                class="kpiTileContainer">

                <GenericTile id="_IDGenGenericTile1"
                    class="kpiTile totalTile"
                    tooltip="View total STOs"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent">
                        <VBox id="_IDGenVBox1" class="tileVBox">
                            <Text id="_IDGenText" text="{dashboard>/counts/TOTAL_STOS}" class="tileCount"/>
                            <Text id="_IDGenText1" text="TOTAL STOs" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile2"
                    class="kpiTile openTile"
                    tooltip="View open STOs"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent1">
                        <VBox id="_IDGenVBox2" class="tileVBox">
                            <Text id="_IDGenText2" text="{dashboard>/counts/OPEN_STOS}" class="tileCount"/>
                            <Text id="_IDGenText3" text="OPEN STOs" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile3"
                    class="kpiTile warningTile"
                    tooltip="View STOs with delivery pending"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent2">
                        <VBox id="_IDGenVBox3" class="tileVBox">
                            <Text id="_IDGenText4" text="{dashboard>/counts/DELIVERY_PENDING}" class="tileCount"/>
                            <Text id="_IDGenText5" text="DELIVERY PENDING" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile5"
                    class="kpiTile warningTile"
                    tooltip="View STOs with PGI pending"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent4">
                        <VBox id="_IDGenVBox5" class="tileVBox">
                            <Text id="_IDGenText8" text="{dashboard>/counts/PGI_PENDING}" class="tileCount"/>
                            <Text id="_IDGenText9" text="PGI PENDING" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile7"
                    class="kpiTile warningTile"
                    tooltip="View STOs with GR pending"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent6">
                        <VBox id="_IDGenVBoxk7" class="tileVBox">
                            <Text id="_IDGenText12" text="{dashboard>/counts/GR_PENDING}" class="tileCount"/>
                            <Text id="_IDGenText13" text="GR PENDING" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile8"
                    class="kpiTile warningTile"
                    tooltip="View STOs with billing pending"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent7">
                        <VBox id="_IDGenVBox8" class="tileVBox">
                            <Text id="_IDGenText14" text="{dashboard>/counts/BILLING_PENDING}" class="tileCount"/>
                            <Text id="_IDGenText15" text="BILLING PENDING (IC)" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile10"
                    class="kpiTile warningTile"
                    tooltip="View STOs with Invoice Pending"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent9">
                        <VBox id="_IDGenVBox10" class="tileVBox">
                            <Text id="_IDGenText18" text="{dashboard>/counts/INVOICE_BLOCKED}" class="tileCount"/>
                            <Text id="_IDGenText19" text="INVOICE PENDING (IC)" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>

                <GenericTile id="_IDGenGenericTile11"
                    class="kpiTile successTile"
                    tooltip="View completed STOs"
                    press="onTilePress">

                    <TileContent id="_IDGenTileContent10">
                        <VBox id="_IDGenVBox11" class="tileVBox">
                            <Text id="_IDGenText20" text="{dashboard>/counts/COMPLETED}" class="tileCount"/>
                            <Text id="_IDGenText21" text="COMPLETED" class="tileTitle"/>
                        </VBox>
                    </TileContent>
                </GenericTile>
            </HBox>

            <smartFilterBar:SmartFilterBar
                id="smartFilterBar"
                entitySet="Dashboard" showFilterConfiguration="false" useToolbar="false" class="sapUiTinyMargin  sSmartFilerBar"/>

                <smartTable:SmartTable
                    id="smartTable"
                    entitySet="Dashboard"
                    smartFilterId="smartFilterBar"
                    tableType="Table"
                    useVariantManagement="false"
                    useTablePersonalisation="true"
                    showRowCount="true"
                    enableAutoBinding="true"
                    persistencyKey="DashboardTable"
                    header="{dashboard>/CurrentStage}" initialise="onSmartTableInitialise" 
                    beforeRebindTable="onBeforeRebindTable"
                    class="smartTable sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginBottom" height="45%"
                    requestAtLeastFields="CreatedBy,SupplyingCompanyCode,ReceivingCompanyCode,Customer,ProcessType,Vendor">

                    <table:Table id="_IDGenTable"
                        selectionMode="None"
                        visibleRowCount="5"
                        alternateRowColors="true"
                        rowSelectionChange="onRowPress"> 

                     </table:Table>

                </smartTable:SmartTable>

            
        
        </content>

    </Page>
</mvc:View>